<UserControl
    x:Class="AmalgadonPlugin.Controls.OverlayButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    d:DesignWidth="210" d:DesignHeight="36"
    Visibility="Collapsed">

    <!-- Single outer border gives the whole control one cohesive Amalgadon-styled pill -->
    <Border Background="#DD221508"
            BorderBrush="#c89b3c"
            BorderThickness="1"
            CornerRadius="4">
        <StackPanel Orientation="Horizontal">

            <!-- Drag handle (left) — grab here to reposition the button -->
            <Border x:Name="DragHandle"
                    Padding="8,0"
                    BorderBrush="#c89b3c"
                    BorderThickness="0,0,1,0"
                    Background="Transparent"
                    ToolTip="Drag to reposition">
                <TextBlock Text="⠿"
                           Foreground="#c89b3c"
                           FontSize="14"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False" />
            </Border>

            <!-- Main action button — no outer border; inherits it from the parent Border -->
            <Button x:Name="OpenButton"
                    Content="Open in Amalgadon"
                    Click="OpenButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background"      Value="Transparent" />
                        <Setter Property="Foreground"      Value="#f0e6c8" />
                        <Setter Property="FontSize"        Value="13" />
                        <Setter Property="FontWeight"      Value="SemiBold" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding"         Value="12,6" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Inner"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Inner" Property="Background" Value="#553a2a18" />
                                            <Setter Property="Foreground" Value="#e8c060" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Inner" Property="Background" Value="#881a1008" />
                                            <Setter Property="Foreground" Value="#b08030" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

        </StackPanel>
    </Border>
</UserControl>
